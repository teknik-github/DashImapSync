NUXT_DB_HOST=127.0.0.1
NUXT_DB_PORT=3306
NUXT_DB_USER=root
NUXT_DB_PASSWORD=secret
NUXT_DB_NAME=dash_imapsync

# Single admin login for the dashboard.
NUXT_ADMIN_USERNAME=admin
# NUXT_ADMIN_PASSWORD accepts either a plaintext password or a SHA-256 hex digest.
# Storing a pre-hashed value is recommended so the plaintext never appears in config files.
# Generate with: echo -n "your-password" | sha256sum | awk '{print $1}'
NUXT_ADMIN_PASSWORD=change-this-admin-password

# Used to sign the admin session cookie.
NUXT_AUTH_SECRET=change-this-auth-secret

# Used to encrypt mailbox passwords at rest.
# Use a long random string in production.
NUXT_IMAPSYNC_SECRET_KEY=change-this-secret-key

# Path or command name for the imapsync binary.
NUXT_IMAPSYNC_BINARY=imapsync

# Number of runs processed at the same time.
NUXT_IMAPSYNC_CONCURRENCY=1

# How often the queue is polled for new runs.
NUXT_IMAPSYNC_QUEUE_POLL_MS=5000
